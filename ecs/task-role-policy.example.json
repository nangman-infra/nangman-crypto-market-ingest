        "s3:GetBucketLocation",
        "s3:ListBucket",
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::nangman-crypto-dev-market-ingest-l1-<account-suffix>",
        "arn:aws:s3:::nangman-crypto-dev-market-ingest-l1-<account-suffix>/*"
      ]
    }
  ]
}
